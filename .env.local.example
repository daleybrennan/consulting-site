# ============================================================
# Copy to .env.local and fill in. Everything except ANTHROPIC_API_KEY
# is optional for running the dev server, but the lead→pitch pipeline
# needs Supabase + Anthropic to actually work end-to-end.
# ============================================================

# Public site URL (used for canonical/hreflang/sitemap and admin links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic (required for pitch generation) -------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (required to persist leads + store PDFs) -----------
# Create a free project at supabase.com, run supabase/migrations/0001_init.sql
# in the SQL editor, and create an admin user (Authentication → Users).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # Project settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # Project settings → API → service_role (server only!)

# Restrict the admin dashboard to a single email (recommended)
ADMIN_EMAIL=daleybrennan@me.com

# --- Cloudflare Turnstile (optional; bot/cost protection) --------
# Without these, the form skips the captcha (fine for local dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Telegram owner notifications (optional) ---------------------
# Owner alert on each form submission. Create a bot via @BotFather for the
# token; message the bot, then read your chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates. Logs to console if unset.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email sending via IONOS SMTP (optional; all outbound mail) --
# Powers the submitter acknowledgment, the owner email alert, and the
# approve-send diagnostic delivery. SMTP_USER must be a real IONOS mailbox
# (a forwarding-only alias cannot authenticate). SMTP_PASS is the mailbox
# password. Replies to SMTP_FROM forward to Daley's iCloud.
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=contact@daleybrennan.com
SMTP_PASS=
SMTP_FROM="Daley Brennan <contact@daleybrennan.com>"

# Where owner alerts (new submissions) are emailed. Falls back to ADMIN_EMAIL.
OWNER_EMAIL=daleybrennan@me.com
