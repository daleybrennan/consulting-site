# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# prospecting agent runtime log (state JSON under data/ is intentionally tracked)
/data/harvest.log

# python bytecode (harvest agent)
__pycache__/
*.pyc

# supabase CLI temp state (regenerated locally)
/supabase/.temp/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep the secret-free example for collaborators
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
